<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/settings_toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_green"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Font Size -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="حجم الخط" android:textColor="@color/accent_green"
                android:textSize="13sp" android:textStyle="bold"
                android:paddingBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <SeekBar android:id="@+id/seek_font_size"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:max="18" android:progress="4"
                    android:progressTint="@color/olive_green"
                    android:thumbTint="@color/accent_green"/>
                <TextView android:id="@+id/label_font_size"
                    android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="14sp" android:textColor="@color/text_primary"
                    android:gravity="center" android:fontFamily="monospace"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_color" android:layout_marginVertical="16dp"/>

            <!-- Word Wrap -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="التفاف النص"
                    android:textColor="@color/text_primary" android:textSize="15sp"/>
                <Switch android:id="@+id/switch_word_wrap"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:thumbTint="@color/accent_green"
                    android:trackTint="@color/olive_green"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_color" android:layout_marginVertical="12dp"/>

            <!-- Auto Indent -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="المسافة البادئة التلقائية"
                    android:textColor="@color/text_primary" android:textSize="15sp"/>
                <Switch android:id="@+id/switch_auto_indent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/accent_green"
                    android:trackTint="@color/olive_green"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border_color" android:layout_marginVertical="12dp"/>

            <!-- Syntax Highlighting -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="تلوين الكود"
                    android:textColor="@color/text_primary" android:textSize="15sp"/>
                <Switch android:id="@+id/switch_syntax_hl"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/accent_green"
                    android:trackTint="@color/olive_green"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
