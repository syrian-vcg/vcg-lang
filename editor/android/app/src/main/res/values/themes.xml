<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main app theme -->
    <style name="Theme.VCGEditor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/olive_green</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
    </style>

    <!-- Splash theme (no action bar) -->
    <style name="Theme.VCGEditor.Splash" parent="Theme.VCGEditor">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Custom dialog style -->
    <style name="VCGDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="buttonBarPositiveButtonStyle">@style/VCGButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/VCGButtonOutlined</item>
    </style>

    <style name="VCGButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/olive_green</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="VCGButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_color</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>
</resources>
